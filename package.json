    "test": "vitest run"
  },
  "packageManager": "npm@11.9.0",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
